                  "// 解析返回的JSON\r",
                  "let res = pm.response.json();\r",
                  "// 把token存到测试环境变量里\r",
                  "pm.environment.set(\"token\", res.token);\r",
                  "console.log(\"登录成功，token已存入环境变量：\", res.token);\r",
                  "// 断言1：验证响应状态码是201\r",
                  "pm.test(\"登录成功，状态码为201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "// 断言2：验证token不为空\r",
                  "pm.test(\"成功获取token\", function () {\r",
                  "    pm.expect(res.token).to.be.a('string').and.not.empty;\r",
                  "});"
